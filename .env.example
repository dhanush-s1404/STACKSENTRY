# ============================================================
# StackSentry Technologies - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
# Application name displayed in UI
APP_NAME=StackSentry Technologies

# Base URL of the application (no trailing slash)
APP_URL=http://localhost:8000

# Environment: development, staging, production
ENVIRONMENT=development

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# PostgreSQL connection URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stacksentry

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stacksentry

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Secret key for signing JWT access tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=CHANGE_ME_generate_a_secure_random_string

# Secret key for signing JWT refresh tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
REFRESH_SECRET_KEY=CHANGE_ME_generate_a_different_secure_random_string

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ------------------------------------------------------------
# SMTP / Email
# ------------------------------------------------------------
# SMTP server for sending emails (verification, password reset, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@stacksentry.com
SMTP_FROM_NAME=StackSentry Technologies

# ------------------------------------------------------------
# AWS S3 (file storage)
# ------------------------------------------------------------
# AWS S3 bucket for storing resumes, documents, and avatars
AWS_S3_BUCKET=stacksentry-uploads
AWS_S3_REGION=ap-south-1
AWS_S3_ACCESS_KEY=your-aws-access-key
AWS_S3_SECRET_KEY=your-aws-secret-key

# ------------------------------------------------------------
# File Upload
# ------------------------------------------------------------
# Local directory for file uploads (used when S3 is not configured)
UPLOAD_DIR=uploads

# Maximum file size in bytes (default: 5MB)
MAX_FILE_SIZE=5242880

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
# Rate limit for API endpoints (format: N/period)
RATE_LIMIT=100/minute

# ------------------------------------------------------------
# Captcha
# ------------------------------------------------------------
# reCAPTCHA secret key for form protection
CAPTCHA_SECRET=your-recaptcha-secret-key

# ------------------------------------------------------------
# Ports (used by docker-compose)
# ------------------------------------------------------------
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443
